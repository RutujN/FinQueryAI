# Groq API Key (Required for LLM generation)
# Get your key here: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face Access Token (Optional, but highly recommended to avoid API rate limiting)
# Get a free read token here: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Application Configuration
HOST=127.0.0.1
PORT=8000
